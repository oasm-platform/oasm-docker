# SHARED CONFIGURATION
IMAGE_TAG=latest
OASM_CLOUD_APIKEY=change_me

# OASM CORE CONFIGURATION
POSTGRES_HOST=postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_DB=open_asm
POSTGRES_SSL=false
PORT=6277
REDIS_URL=redis://:open_asm@redis:6379/0
