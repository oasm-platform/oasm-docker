# APP CONFIGURATION
ASSISTANT_HOST=0.0.0.0
ASSISTANT_PORT=8000

# GeoIP CONFIGURATION
GEO_IP_URL=geo-ip-database:4360

# RustFS Configuration
RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfssecret